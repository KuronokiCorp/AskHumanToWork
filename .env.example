# --- Database ---
DATABASE_URL=postgres://localhost:5432/askhumantowork

# --- API server ---
API_PORT=3000
API_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:5173
SESSION_SECRET=change-me-32-chars-minimum-secret!!
# AES-256-GCM key for encrypting OAuth tokens at rest (32 bytes, base64)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Email (Mailpit locally: SMTP :1025, UI http://localhost:8025) ---
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=reminders@askhumantowork.local

# --- Web push (VAPID). Generate: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@askhumantowork.local

# --- Integration provider OAuth apps (optional; can also be set in Admin UI) ---
MS_TODO_CLIENT_ID=
MS_TODO_CLIENT_SECRET=
GOOGLE_TASKS_CLIENT_ID=
GOOGLE_TASKS_CLIENT_SECRET=

# --- Production hardening ---
# COOKIE_SECURE=true   # behind HTTPS
# TRUST_PROXY=true     # behind a reverse proxy / load balancer
# SERVE_WEB=true       # serve packages/web/dist from the API process (single-container deploy)

# --- AI digest (optional) ---
# When set, the morning digest email is written by Claude; otherwise a template is used.
# ANTHROPIC_API_KEY=sk-ant-...
