{
  "name": "@askhumantowork/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@askhumantowork/core": "workspace:*",
    "@askhumantowork/db": "workspace:*",
    "@askhumantowork/shared": "workspace:*",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/session": "^11.0.1",
    "@fastify/static": "^9.3.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "nodemailer": "^6.9.16",
    "pg": "^8.22.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1",
    "heyhuman-mcp": "workspace:*"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
