{
  "name": "heyhuman-mcp",
  "version": "0.1.0",
  "description": "HeyHuman MCP connector — let Claude (or any MCP client) capture todos into HeyHuman and remind you until they are done. Thin HTTP client for the hosted API; no database required.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "heyhuman-mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "todo",
    "claude",
    "ai-agents",
    "reminders"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@askhumantowork/shared": "workspace:*",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KuronokiCorp/AskHumanToWork.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/KuronokiCorp/AskHumanToWork#readme",
  "bugs": {
    "url": "https://github.com/KuronokiCorp/AskHumanToWork/issues"
  }
}
